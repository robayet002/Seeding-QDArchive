      <geogCover>The survey had national coverage.</geogCover>
      <geogUnit/>
      <anlyUnit>Individuals and institutions</anlyUnit>
      <universe>The target group of the survey are learners aged 13-15 years in the selected schools.</universe>
      <dataKind>Sample survey data [ssd]</dataKind>
    </sumDscr>
